# Optional: Firecrawl API key (improves non-XHS reads)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxx

# Optional: Override output directory (defaults to your local Obsidian path)
URL_READER_OUTPUT_DIR=/path/to/your/obsidian/🌐 网络收藏

# Optional: Provenance marker for generated notes
# Use "commercial" for commercially licensed deployments.
URL_READER_LICENSE_MODE=AGPL-3.0-or-later
